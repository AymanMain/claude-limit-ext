{
  "name": "claude-session-tracker",
  "version": "0.1.1",
  "private": true,
  "description": "Track Claude usage windows, reset countdowns, and local alerts from the browser toolbar.",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "package:chrome": "npm run check && node scripts/package-chrome.mjs",
    "package:edge": "npm run check && node scripts/package-edge.mjs",
    "package:opera": "npm run check && node scripts/package-opera.mjs",
    "package:all": "npm run package:chrome && npm run package:edge && npm run package:opera",
    "release:validate": "node scripts/validate-release.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vite-plugin-web-extension": "^4.1.0",
    "vitest": "^1.6.0"
  }
}
