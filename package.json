{
  "name": "claude-limit-tracker",
  "version": "0.1.1",
  "private": true,
  "description": "Track Claude usage limits — 5-hour and 7-day windows with reset countdowns",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && cd dist && zip -r ../claude-limit-tracker.zip . && cd .."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vite-plugin-web-extension": "^4.1.0",
    "vitest": "^1.6.0"
  }
}
